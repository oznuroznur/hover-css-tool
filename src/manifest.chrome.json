{
  "manifest_version": 3,
  "name": "CSS Inspector",
  "version": "0.1.0",
  "description": "Pick any element on a page and copy its styles as CSS, SCSS or Tailwind classes.",
  "homepage_url": "https://github.com/oznuroznur/hover-css-tool",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "CSS Inspector — toggle inspect mode",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "scripting"]
}
